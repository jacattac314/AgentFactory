# Hermes Agent Factory — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — needed to actually run agents
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Slack ───────────────────────────────────────────────────────────
# Bot token from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# ── Optional: Gmail ───────────────────────────────────────────────────────────
# Path to your OAuth2 client secret JSON (default: ~/.hermes/gmail_client_secret.json)
# GMAIL_CLIENT_SECRET_PATH=/path/to/client_secret.json

# Path where the OAuth token will be saved (default: ~/.hermes/gmail_token.json)
# GMAIL_TOKEN_PATH=/path/to/gmail_token.json

# After setting GMAIL_CLIENT_SECRET_PATH, run: hermes tools auth gmail

# ── Optional: Web search ─────────────────────────────────────────────────────
# Serper.dev API key for Google-quality search results (free: 2500 queries/month)
# Without this, DuckDuckGo is used automatically — no key needed.
# SERPER_API_KEY=...
