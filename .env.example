# Hermes Agent Factory — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Option A: LM Studio (or any OpenAI-compatible server)
#   1. Open LM Studio → Local Server tab → Start Server
#   2. Load a model with tool-calling support (llama3.2, qwen2.5, etc.)
#   3. Set these vars:
HERMES_BACKEND=openai
HERMES_API_BASE=http://localhost:1234/v1
HERMES_MODEL=llama3.2
# HERMES_API_KEY=lm-studio    # LM Studio ignores the key value; leave as-is

# Option B: Anthropic Claude (cloud)
#   Comment out Option A above and set:
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Slack ───────────────────────────────────────────────────────────
# Bot token from https://api.slack.com/apps → OAuth & Permissions
# SLACK_BOT_TOKEN=xoxb-...

# ── Optional: Gmail ───────────────────────────────────────────────────────────
# Path to your OAuth2 client secret JSON (default: ~/.hermes/gmail_client_secret.json)
# GMAIL_CLIENT_SECRET_PATH=/path/to/client_secret.json
# GMAIL_TOKEN_PATH=/path/to/gmail_token.json
# After setting GMAIL_CLIENT_SECRET_PATH, run: hermes tools auth gmail

# ── Optional: Web search ─────────────────────────────────────────────────────
# Serper.dev API key for Google-quality results (free: 2500 queries/month)
# Without this key, DuckDuckGo is used automatically.
# SERPER_API_KEY=...
